// ==UserScript==
// @name         GL Capital — Consulta Manual
// @namespace    http://tampermonkey.net/
// @version      4.6
// @description  Consulta manual para GL Capital com ID de Diálogo dinâmico
// @match        https://s12.chatguru.app/*
// @match        https://app.chatguru.com.br/*
// @grant        GM_xmlhttpRequest
// @grant        GM_getValue
// @grant        GM_setValue
// @connect      painel.glcapital.ltd
// @updateURL    https://raw.githubusercontent.com/Ante-Deguemon/TAMPERMONKEY-SCRIPTS-GL/refs/heads/main/GL%20Capital%20%E2%80%94%20Consulta%20Manual
// @downloadURL  https://raw.githubusercontent.com/Ante-Deguemon/TAMPERMONKEY-SCRIPTS-GL/refs/heads/main/GL%20Capital%20%E2%80%94%20Consulta%20Manual
// ==/UserScript==

(function () {
  'use strict';

  // --- BUSCA OU SOLICITA A MATRÍCULA ---
  let MATRICULA = GM_getValue('GL_MATRICULA', null);

  if (!MATRICULA) {
    MATRICULA = prompt('Configuração Inicial:\nInsira o seu código de MATRÍCULA:');
    if (MATRICULA && MATRICULA.trim() !== '') {
      MATRICULA = MATRICULA.trim();
      GM_setValue('GL_MATRICULA', MATRICULA);
    } else {
      alert('A matrícula é obrigatória. Atualize a página.');
      return;
    }
  }

  // --- BUSCA OU SOLICITA O ID DO DIÁLOGO ---
  let ID_DIALOGO = GM_getValue('ID_DIALOGO', null);

  if (!ID_DIALOGO) {
    ID_DIALOGO = prompt('Configuração Inicial:\nInsira o ID DO DIÁLOGO:');
    if (ID_DIALOGO && ID_DIALOGO.trim() !== '') {
      ID_DIALOGO = ID_DIALOGO.trim();
      GM_setValue('ID_DIALOGO', ID_DIALOGO);
    } else {
      alert('O ID do Diálogo é obrigatório. Atualize a página.');
      return;
    }
  }

  const GL_API = 'https://glcapital-credfacil.ngrok.pro/api/consulta/manual';

  function notificar() {
    GM_xmlhttpRequest({
      method: 'POST',
      url: GL_API,
      headers: { 'Content-Type': 'application/json' },
      data: JSON.stringify({ matricula: MATRICULA, link_chat: window.location.href }),
      onload: (res) => console.log('[GL] notify-pending:', res.status),
      onerror: (err) => console.warn('[GL] notify-pending erro:', err),
    });
  }

  // ---------- s12.chatguru.app — F2 clica no botão + notifica ----------

  if (location.hostname === 's12.chatguru.app') {
    document.addEventListener('keydown', function (e) {
      if (e.code !== 'F2') return;

      // Seletor usando o ID salvo no storage
      const selector = `button[data-dialog-id="${ID_DIALOGO}"]`;

      if (typeof $ !== 'undefined') {
        const jqBtn = $(selector);
        if (jqBtn.length > 0) {
          e.preventDefault();
          jqBtn.click();
          notificar();
          return;
        }
      }

      const jsBtn = document.querySelector(selector);
      if (jsBtn) {
        e.preventDefault();
        jsBtn.click();
        notificar();
      }
    });
  }

  // ---------- app.chatguru.com.br — notifica o backend ----------

  if (location.hostname === 'app.chatguru.com.br') {
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-gl-consultar], .btn-consultar');
      if (btn) notificar();
    });

    window.__glNotificarPendente = notificar;
  }
})();
